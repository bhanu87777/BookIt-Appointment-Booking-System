# ─────────────────────────────────────────────────────────────
# BookIt — server environment configuration
# Copy this file to `server/.env` and fill in the values.
# NEVER commit your real `.env` — only this example is tracked.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# URL-encode any special characters in the password (e.g. # -> %23, @ -> %40).
# The database is created automatically by `npm run db:migrate` if it doesn't exist.
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/appointments

# ── Server ──
PORT=4000
# Secret used to sign admin JWTs. Generate a strong one for production:
#   openssl rand -base64 32
JWT_SECRET=change-me-in-production
# Origin allowed by CORS (your client dev server).
CLIENT_ORIGIN=http://localhost:5173

# ── Email (optional) ──
# If SMTP_HOST is NOT set, confirmation/cancellation emails are rendered to
# server/outbox/*.html so you can inspect them without a mail provider.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="BookIt <no-reply@bookit.local>"

# ─────────────────────────────────────────────────────────────
# BookIt — server environment configuration
# Copy this file to `server/.env` and fill in the values.
# NEVER commit your real `.env` — only this example is tracked.
# ─────────────────────────────────────────────────────────────

# PostgreSQL connection string.
# URL-encode any special characters in the password (e.g. # -> %23, @ -> %40).
# The database is created automatically by `npm run db:migrate` if it doesn't exist.
DATABASE_URL=postgres://postgres:YOUR_PASSWORD@localhost:5432/appointments

# ── Server ──
PORT=4000
# Secret used to sign admin JWTs. Generate a strong one for production:
#   openssl rand -base64 32
JWT_SECRET=change-me-in-production
# Origin allowed by CORS (your client dev server).
CLIENT_ORIGIN=http://localhost:5173

# ── Email (optional) ──
# If SMTP_HOST is NOT set, all emails (confirmations, reminders, receipts…)
# are rendered to server/outbox/*.html so you can inspect them without a
# mail provider. Delivery is queued with retries either way.
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=
# SMTP_PASS=
# MAIL_FROM="BookIt <no-reply@bookit.local>"

# ── Payments ──
# 'mock' ships a fully simulated gateway (no external account needed).
# The adapter interface is production-shaped, so a real gateway can be added.
PAYMENT_PROVIDER=mock
# Minutes a slot is held while the customer completes payment.
PAYMENT_HOLD_MINUTES=10
# HMAC secret for the mock gateway's simulated checkout signatures.
MOCK_PAY_SECRET=mockpay-dev-secret

# ── Refund policy (customer cancellations of paid bookings) ──
# Full refund if cancelled at least this many hours before start:
REFUND_FULL_BEFORE_HOURS=24
# Cancellation fee (percent of paid amount) inside that window:
REFUND_FEE_PCT=25
# No refund when cancelling within this many hours of start:
REFUND_NONE_WITHIN_HOURS=2
